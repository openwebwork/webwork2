% use WeBWorK::Utils qw(getAssetURL);
%
% content_for css => begin
	<%= stylesheet getAssetURL($ce, 'js/Grades/grades.css') =%>
% end
%
<%= $c->displayStudentGrades =%>
%
% my $scoring_info = $c->scoring_info;
% if ($scoring_info) {
	<h2><%= maketext('Additional Grade Information') %></h2>
	<%= $scoring_info =%>
% }
