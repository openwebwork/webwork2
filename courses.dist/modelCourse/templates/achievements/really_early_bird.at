# This achievement is awarded for completing a set within 2 hours
# or 2 * 60 * 60 = 7200 seconds of it opening.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check if this set has been completed.
return 0 unless $globalData->{completedSetIds}{ $set->set_id };

# Now test if it is before 2 hours after the open date.
return time - $set->open_date > 7200 ? 0 : 1;
