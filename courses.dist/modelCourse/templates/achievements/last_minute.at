# Achievement is awarded if the set is completed within thirty
# minutes of the due date.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check if this set has been completed.
return 0 unless $globalData->{completedSetIds}{ $set->set_id };

# Do not consider this achievement if this is a repeated submission
# of previously solved problem.
return 0 unless $problem->num_correct == 1;

# Thirty minutes = 30 * 60 = 1800 seconds.
return $set->due_date - time > 1800 ? 0 : 1;
