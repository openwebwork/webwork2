# This achievement is awarded for completing a set within 1 day
# or 24 * 60 * 60 = 86400 seconds of it opening.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check if this set has been completed.
return 0 unless $globalData->{completedSetIds}{ $set->set_id };

# Now test if it is before 1 day after the open date.
return time - $set->open_date > 86400 ? 0 : 1;
