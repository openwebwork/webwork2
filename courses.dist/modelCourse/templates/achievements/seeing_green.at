# This achievement is rewarded for completing a set with no incorrect
# submissions.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check if this set has been completed.
return 0 unless $globalData->{completedSetIds}{ $set->set_id };

# Check if any problem has an incorrect submission.
for my $problemRecord (@setProblems) {
	return 0 unless $problemRecord->num_incorrect == 0;
}

# No incorrect submissions found. Award achievement.
return 1;
