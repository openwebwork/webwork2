# This achievement is awarded for finishing a set with fewer than
# 5 incorrect submissions.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check if set is complete.
return 0 unless $globalData->{completedSetIds}{ $set->set_id };

# Count up the number of incorrect submissions.
my $numIncorrect = 0;
for my $problemRecord (@setProblems) {
	$numIncorrect += $problemRecord->num_incorrect;
	return 0 if $numIncorrect > 5;
}

return 1;
