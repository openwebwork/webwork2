# This achievement is awarded if a problem is completed at the
# top of an hour.
#
# See [templates]/achievements/achievement_readme.txt for details.

# Check to see if is the top of an hour.
return 0 unless $courseDateTime[1] == 0;

# Check to see if the problem is completed and this is the first time.
return $problem->status == 1 && $problem->num_correct == 1 ? 1 : 0;
